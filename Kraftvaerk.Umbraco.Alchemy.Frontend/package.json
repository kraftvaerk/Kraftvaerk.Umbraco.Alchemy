{
  "name": "Kraftvaerk.Umbraco.Alchemy.frontend",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc && vite build",
    "watch": "node ./build/watch.js ./../../Umbraco wwwroot/app_plugins/Kraftvaerk.Umbraco.Alchemy.Frontend",
    "init-umbraco": "node build/umbraco.js init-umbraco",
    "test-umbraco": "node build/umbraco.js test-umbraco",
    "remove-umbraco": "node build/umbraco.js remove-umbraco",
    "usync": "node build/umbraco.js usync",
    "sync-ai": "node build/umbraco.js sync-ai",
    "generate": "cross-env NODE_TLS_REJECT_UNAUTHORIZED=0 openapi-ts --file openapi-ts.config.ts",
    "publish": "node build/umbraco.js publish",
    "skills:copilot": "npx skills add umbraco/Umbraco-CMS-Backoffice-Skills --skill * -a github-copilot",
    "skills:cursor": "npx skills add umbraco/Umbraco-CMS-Backoffice-Skills --skill * -a cursor",
    "skills:windsurf": "npx skills add umbraco/Umbraco-CMS-Backoffice-Skills --skill * -a windsurf",
    "skills:claude": "npx skills add umbraco/Umbraco-CMS-Backoffice-Skills --skill * -a claude"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "lit": "^3.1.4"
  },
  "devDependencies": {
    "@types/node": "^22.2.0",
    "@umbraco-cms/backoffice": "^17.0.0",
    "better-sqlite3": "^12.8.0",
    "cross-env": "^7.0.3",
    "dotenv": "^16.4.5",
    "eslint": "^9.9.0",
    "inquirer": "^10.1.8",
    "typescript": "^5.2.2",
    "vite": "^5.3.1"
  }
}
