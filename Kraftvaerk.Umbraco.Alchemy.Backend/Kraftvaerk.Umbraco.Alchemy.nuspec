<?xml version="1.0"?>
<package>
	<metadata>
		<id>Kraftvaerk.Umbraco.Alchemy</id>
		<version>0.0.10</version>
		<authors>Umbraco.Community</authors>
		<owners>Umbraco.Community</owners>
		<requireLicenseAcceptance>false</requireLicenseAcceptance>
		<description>This is a sample package for Umbraco</description>
		<readme>README.md</readme>
		<title>Kraftvaerk.Umbraco.Alchemy</title>
		<dependencies>
			<group targetFramework="net10.0">
				<dependency id="Umbraco.Cms" version="[17.0.0,18.0.0)" />
			</group>
			<group targetFramework="net9.0">
				<dependency id="Umbraco.Cms" version="[15.0.0,17.0.0)" />
			</group>
			<group targetFramework="net8.0">
				<dependency id="Umbraco.Cms" version="[14.0.0,15.0.0)" />
			</group>
		</dependencies>
	</metadata>
	<files>
		<!-- Include compiled DLLs for each target framework -->
		<file src="bin\Release\net10.0\*.dll" target="lib/net10.0" />
		<file src="bin\Release\net9.0\*.dll" target="lib/net9.0" />
		<file src="bin\Release\net8.0\*.dll" target="lib/net8.0" />

		<!-- Include frontend files -->
		<file src="ui\**\*.*" target="contentFiles/any/any/ui/" />

		<!-- Include the targets file -->
		<file src="build\nuget.targets" target="build\nuget.targets" />
	</files>
</package>
